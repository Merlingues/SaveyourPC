#!/bin/bash
echo "COMMANDES UTILES :"
echo "-----------------------------------------------------------------------"
echo "- help"
echo "Affiche les commandes et leur mode de fonctionnement"
echo "-----------------------------------------------------------------------"
echo "- curl [url]"
echo "Affiche un site web dans la CLI"
echo "-----------------------------------------------------------------------"
echo "- search [mot]"
echo "Permet de faire une recherche d'un mot dans les noms dossiers/fichiers"
echo "-----------------------------------------------------------------------"
echo "- echo "[texte]" >> fichier"
echo "Ajouter du texte dans un fichier"
echo "-----------------------------------------------------------------------"
echo "- ps-list"
echo "Affiche les processus en cours (admin)"
echo "-----------------------------------------------------------------------"
echo "- pkill [nom du proc]"
echo "kill un processus (admin)"
echo "-----------------------------------------------------------------------"
echo "- nsnake"
echo "Lance le jeu snake"
echo "-----------------------------------------------------------------------"
echo "- login [identifiant]"
echo "Permet de se connecter en tant qu'user spécifique"
echo "-----------------------------------------------------------------------"
echo "- decrypte [clé d'encryption] [texte]"
echo "Permet de decrypter un texte via une clé d'encryption"
echo "-----------------------------------------------------------------------"
echo "- cat [chemin du fichier]"
echo "Permet d'afficher le contenu d'un fichier"
echo "-----------------------------------------------------------------------"
echo "- fortune"
echo "Répend la bonne fortune (ça peut être utile)"
echo "-----------------------------------------------------------------------"
echo "- cd [chemin]"
echo "Permet de se déplacer vers un dossier, si [chemin] = .. permet de revenir dans le dossier parent"
echo "-----------------------------------------------------------------------"
echo "- ls [chemin]"
echo "Affiche les éléments visible dans le dossier du [chemin]"
echo "-----------------------------------------------------------------------"
echo "- sl [chemin]"
echo "Affiche les éléments visible dans le dossier du [chemin]"
echo "-----------------------------------------------------------------------"
echo "- pwd"
echo "Affiche le chemin absolu du dossier actuel"
echo "-----------------------------------------------------------------------"
echo "- exit"
echo "Permet de se deconnecter de l'utilisateur actuel"
echo "-----------------------------------------------------------------------"
echo "- clear"
echo "Permet de purger la CLI"