#!/bin/bash
SCORE_FILE="/tmp/game_score.txt"
dossiers_autorises=("/foret/maison/" "/home/user/" "/home/admin/" "/foret/maison" "/home/user" "/home/admin")

# 1. On vérifie d'abord si l'utilisateur a essayé de mettre une option (ex: -la)
if [[ "$1" == -* ]]; then
    echo "La commande ls ne contient aucune option."
    echo "Usage : ls /chemin/du/dossier"
    exit 1
fi

# 2. On vérifie si le chemin est dans la liste autorisée
authoriser=false
for path in "${dossiers_autorises[@]}"; do
    if [[ "$1" == "$path" ]]; then
        authoriser=true
        break
    fi
done

# 3. On agit en fonction de l'autorisation
if [ "$authoriser" = true ]; then
    /usr/bin/ls "$1"
    
    # On donne les points si c'est le bon dossier
    if [[ "$1" == *"foret/maison"* ]]; then
        echo 2 > "$SCORE_FILE"
    fi
else
    # Si le chemin n'est pas autorisé, on affiche l'erreur et ON ARRÊTE le script
    echo "Chemin incorrect"
    exit 1
fi