#!/bin/bash
SCORE_FILE="/tmp/game_score.txt"

# 1. On bloque immédiatement si l'utilisateur met un tiret (option)
if [[ "$1" == "-"* ]]; then
    echo "La commande ls ne contient aucune option."
    echo "Usage : ls /chemin/du/dossier"
    exit 1
fi

# 2. Nouvelle solution : On utilise un 'case' pour valider le chemin
# C'est beaucoup plus robuste que les boucles for pour un Escape Game
case "$1" in
    "/foret/maison/"|"/foret/maison")
        /usr/bin/ls "$1"
        echo 2 > "$SCORE_FILE"
        exit 0 # Succès total, on arrête tout ici
        ;;
    "/home/user/"|"/home/user"|"/home/admin/"|"/home/admin")
        /usr/bin/ls "$1"
        exit 0 # Succès (sans points), on arrête tout ici
        ;;
    *)
        # Si le chemin n'est pas dans la liste au-dessus
        echo "Chemin incorrect"
        exit 1
        ;;
esac