#!/bin/bash
SCORE_FILE="/tmp/game_score.txt"
dossiers_autorises=("/foret/maison/" "/home/user/" "/home/admin/" "/foret/maison" "/home/user" "/home/admin")

# 1. On nettoie l'argument (optionnel mais recommandé)
ENTREE="$1"

# 2. On vérifie les options EN PREMIER avec une syntaxe plus stricte
if [[ "$ENTREE" =~ ^- ]]; then
    echo "La commande ls ne contient aucune option."
    echo "Usage : ls /chemin/du/dossier"
    exit 1
fi

# 3. On vérifie si le chemin est dans la liste
authoriser=false
for path in "${dossiers_autorises[@]}"; do
    if [[ "$ENTREE" == "$path" ]]; then
        authoriser=true
        break
    fi
done

# 4. Exécution
if [ "$authoriser" = true ]; then
    /usr/bin/ls "$ENTREE"
    
    # Attribution des points
    if [[ "$ENTREE" == *"foret/maison"* ]]; then
        echo 2 > "$SCORE_FILE"
    fi
    exit 0 # Succès, on quitte proprement ici
else
    # Si on arrive ici, c'est que le chemin n'était pas dans la liste
    echo "Chemin incorrect"
    exit 1
fi