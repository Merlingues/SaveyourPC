#!/bin/bash

if [ "$#" -ne 2 ]; then
    echo "Usage : decrypt [dĂŠcalage] [texte]"
    exit 1
fi
if [["$2" == *"qjyrjns"*]]; then
    echo 3 > "$SCORE_FILE"
fi
shift_val=$(( ($1 % 26 + 26) % 26 ))

alphabet="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
alphabet_lower="abcdefghijklmnopqrstuvwxyz"

shifted_upper="${alphabet:$shift_val}${alphabet:0:$shift_val}"
shifted_lower="${alphabet_lower:$shift_val}${alphabet_lower:0:$shift_val}"

echo "$2" | tr "$shifted_upper$shifted_lower" "$alphabet$alphabet_lower"